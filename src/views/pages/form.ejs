<%- include('../partials/header') %>
    <main>
        <div class="container py-3 py-md-5">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-11 col-md-9 col-lg-8 col-xl-10">
                    <div class="card form-card shadow bg-white">
                        <div class="card-body p-3 p-sm-4 p-md-5">
                            <div class="text-center mb-4">
                                <h1 class="form-title"><%= formTitle %></h1>
                            </div>
                            <form action="<%= formAction %>" id="<%= idForm %>" novalidate>
                                <% inputs.forEach(function(input) { %>
                                    <div class="mb-3">
                                        <% if(input.type === 'select') { %>
                                            <label for="<%= input.id %>" class="form-label"><%= input.label %></label>
                                            <select class="form-select <%= input.class ? input.class : '' %>" id="<%= input.id %>" name="<%= input.name %>" <%= input.required ? 'required' : '' %>>
                                                <option value="">Selecione uma opção</option>
                                                <% input.options.forEach(function(option) { %>
                                                    <option value="<%= option.value %>" <%= option.value === input.value ? 'selected' : '' %>><%= option.label %></option>
                                                <% }); %>
                                            </select>
                                        <% } else if(input.type === 'textarea') { %>
                                            <label for="<%= input.id %>" class="form-label"><%= input.label %></label>
                                            <textarea class="form-control <%= input.class ? input.class : '' %>" id="<%= input.id %>" name="<%= input.name %>" rows="4" <%= input.required ? 'required' : '' %>><%= input.value ? input.value : '' %></textarea>
                                        <% } else { %>
                                            <label for="<%= input.id %>" class="form-label"><%= input.label %></label>
                                            <input type="<%= input.type %>" class="form-control <%= input.class ? input.class : '' %>" id="<%= input.id %>" name="<%= input.name %>" value="<%= input.value ? input.value : '' %>" <%= input.required ? 'required' : '' %>>
                                        <% } %>
                                    </div>
                                <% }); %>
                                <div class="d-grid gap-2 mt-4">
                                    <button type="button" data-method="<%= formMethod %>" data-form-id="<%= idForm %>" data-redirect="<%= typeof redirectUrl !== 'undefined' ? redirectUrl : '' %>" class="btn btn-accent btn-lg btnSend"><%= typeof btnText !== 'undefined' ? btnText : 'Enviar' %></button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
<%- include('../partials/footer') %>
