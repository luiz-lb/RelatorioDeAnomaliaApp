<%- include('../partials/header') %>
    <main class="d-flex justify-content-center align-items-start min-vh-100 py-4 py-md-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-11">

                    <!-- Cabeçalho da página e Ações -->
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                        <div>
                            <h2 class="mb-1 fw-bold text-dark d-flex align-items-center">
                                <i class="bi bi-people-fill text-accent me-2"></i> Gerenciamento de Usuários
                            </h2>
                            <p class="text-muted mb-0">Controle de acessos e permissões do sistema</p>
                        </div>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end mt-3 mt-md-0">
                            <a href="/fiscalizacao"
                                class="btn btn-light shadow-sm text-secondary border d-flex align-items-center gap-2 px-2 fw-medium">
                                <i class="bi bi-arrow-left"></i> Voltar ao Painel
                            </a>
                            <a href="/adm/user/new" class="text-decoration-none d-grid d-sm-block">
                                <button
                                    class="btn btn-accent shadow-sm d-flex justify-content-center align-items-center gap-2 w-100 px-4 fw-medium">
                                    <i class="bi bi-person-plus-fill"></i> Adicionar Usuário
                                </button>
                            </a>
                            <form id="logoutForm" action="/adm/logout" method="POST"></form>
                                <button id="btnLogout" type="button" class="btn btn-light shadow-sm text-secondary border d-flex align-items-center gap-2 px-2 fw-medium">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </button>
                        </div>
                    </div>

                    <!-- Card com a Tabela -->
                    <div class="card shadow-sm border-0 rounded-4 bg-white mb-4">
                        <div class="card-body p-0 overflow-hidden rounded-4">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle border-0 mb-0" id="<%= tableidheader %>">

                                    <% if (typeof tbody !=='undefined' && tbody.length> 0) { %>

                                        <thead class="table-light border-bottom">
                                            <tr>
                                                <% thead.forEach(function(colunaTable) { %>
                                                    <th class="fw-semibold text-secondary py-3 px-4 text-nowrap">
                                                        <%= colunaTable %>
                                                    </th>
                                                    <% }); %>
                                            </tr>
                                        </thead>

                                        <tbody id="<%= tableid %>">
                                            <% tbody.forEach(function(linha) { %>
                                                <tr>
                                                    <% Object.values(linha).forEach(function(dado, index) { %>
                                                        <td class="py-3 text-dark px-4"
                                                            data-label="<%= thead[index] %>">
                                                            <%- dado %>
                                                        </td>
                                                    <% }); %>

                                                    <!-- Ações -->
                                                    <td class="py-3 text-center" data-label="Ações">
                                                        <div class="d-flex gap-2">
                                                            <a href="/adm/user/edit/<%= Object.values(linha)[0] %>"
                                                                class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm d-flex align-items-center gap-1"
                                                                title="Editar">
                                                                <i class="bi bi-pencil"></i> <span
                                                                    class="d-none d-sm-inline">Editar</span>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>

                                        <% } else { %>
                                            <!-- Estado vazio -->
                                            <tbody>
                                                <tr>
                                                    <td colspan="<%= thead.length + 1 %>" class="border-0">
                                                        <div class="text-center py-5">
                                                            <div class="text-muted mb-3">
                                                                <i class="bi bi-people empty-state-icon-large"></i>
                                                            </div>
                                                            <h5 class="text-dark fw-bold mb-2">Nenhum usuário encontrado
                                                            </h5>
                                                            <p class="text-muted mb-4">Comece adicionando um novo
                                                                usuário para visualizar os dados aqui.</p>
                                                            <a href="/adm/user/new"
                                                                class="btn btn-accent px-4 py-2 rounded-pill shadow-sm fw-medium">
                                                                <i class="bi bi-person-plus-fill me-2"></i> Adicionar
                                                                Usuário
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                            <% } %>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>