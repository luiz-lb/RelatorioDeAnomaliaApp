<%- include('../partials/header') %>
    <main class="d-flex justify-content-center align-items-start min-vh-100 py-4 py-md-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-11">
                    <!-- Cabeçalho da Página -->
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                        <div>
                            <h2 class="mb-1 fw-bold text-dark"><i class="bi bi-card-list text-accent me-2"></i>
                                Relatório de Fiscalização</h2>
                            <p class="text-muted mb-0">Detalhes do relatório e registro de não conformidades.</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <% if (resultadoHeader.status==='Concluído' ) { %>
                                <button type="button" id="btn-baixar-relatorio" data-idrelatorio="<%= idRelatorio %>"
                                    class="btn btn-accent px-3 py-2 fw-medium ">
                                    <i class="bi bi-file-earmark-arrow-down-fill me-2"></i>Download Relatório
                                </button>
                            <% } %>
                            <a href="/fiscalizacao"
                                class="btn btn-light shadow-sm text-secondary border px-3 py-2 fw-medium">
                                <i class="bi bi-arrow-left"></i> Voltar ao Painel
                            </a>
                        </div>
                    </div>
                    <!-- Card de Informações Gerais -->
                    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-white">
                        <div
                            class="card-header bg-transparent border-0 p-3 p-md-4 pb-0 d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark-text text-accent"></i> Informações Gerais
                            </h5>
                            <div class="align-items-end py-2 d-flex gap-3">
                                <span
                                    class="badge <%= resultadoHeader.status === 'Concluído' ? 'bg-success' : (resultadoHeader.status === 'Rascunho' ? 'bg-secondary' : 'bg-warning text-dark') %> rounded-pill px-3 py-2 fw-medium">
                                    <%= resultadoHeader.status || 'Pendente' %>
                                </span>
                            </div>
                        </div>
                        <div class="card-body p-3 p-md-4">
                            <div class="row g-4">
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">Site ID</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.site_id || 'N/A' %>
                                    </span>
                                </div>
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">Criado por</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.nome || 'N/A' %>
                                    </span>
                                </div>
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">Criado em</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.created_at_formatado || 'N/A' %>
                                    </span>
                                </div>
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">Estrutura / Altura</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.tipo_estrutura || 'N/A' %> (<%= resultadoHeader.altura_torre
                                                || 'N/A' %>m)
                                    </span>
                                </div>
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">Tipo do Cadeado</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.tipo_cadeado || 'N/A' %>
                                    </span>
                                </div>
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <small class="text-muted d-block">CEP</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.CEP || 'N/A' %>
                                    </span>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted d-block">Endereço Completo</small>
                                    <span class="fw-bold text-dark">
                                        <%= resultadoHeader.endereco || 'N/A' %>, <%= resultadoHeader.municipio || 'N/A'
                                                %> - <%= resultadoHeader.UF || 'N/A' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% if(resultadoHeader.status==='Rascunho') { %>
                            <div class="card-footer bg-transparent border-0 p-3 p-md-4 pt-0 text-end">
                                <button type="button" id="btn-enviar-relatorio" data-relatorio="<%= idRelatorio %>" class="btn btn-accent rounded-pill px-4 py-2 fw-medium shadow-sm w-100 w-sm-auto">
                                    <i class="bi bi-check-circle-fill me-2"></i>Enviar Relatório
                                </button>
                            </div>
                        <% } %>
                    </div>

                    <!-- Seção de Não Conformidades -->
                    <div class="mb-4">
                        <h4 class="mb-3 fw-bold d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill text-accent"></i> Não Conformidades Identificadas
                        </h4>
                        <div id="galeria" class="row g-4">
                            <% if (resultadoBody.length> 0) { %>
                                <% resultadoBody.forEach(function(item) { %>
                                    <%- include('../partials/card-conformidade', { item: item, idRelatorio: idRelatorio, status: resultadoHeader.status }) %>
                                <% }); %>
                            <% } else { %>
                                <div id="sem-naoconformidade" class="col-12" id="empty-state-galeria">
                                    <div class="text-center py-5 px-3 bg-light rounded-4 border">
                                        <div class="text-muted mb-3">
                                            <i class="bi bi-camera empty-state-icon"></i>
                                        </div>
                                        <h5 class="text-muted">Nenhuma não conformidade registrada</h5>
                                        <p class="text-muted small">Use o formulário abaixo para adicionar a primeira imagem.</p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <% if (resultadoHeader.status==='Rascunho' ) { %>
                        <!-- Card para Adicionar Nova Imagem -->
                        <div class="card shadow-sm border-0 rounded-4 bg-white mb-4">
                            <div class="card-header bg-transparent border-0 p-3 p-md-4 pb-0">
                                <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                                    <i class="bi bi-plus-circle-dotted text-accent"></i> Adicionar Nova Não Conformidade
                                </h5>
                                <h6 class="mb-0 d-flex align-items-start gap-2">
                                Recomendamos capturar as fotos na horizontal (modo paisagem) para garantir melhor enquadramento e visualização das informações no relatório.
                                </h6>
                            </div>
                            <div class="card-body p-3 p-md-4">
                                <form id="formUpload" data-relatorio="<%= idRelatorio %>" novalidate>
                                    <div class="mb-3">
                                        <label for="arquivoInput" class="form-label fw-medium">Adicionar Imagem:</label>
                                        <input type="file" id="arquivoInput" accept="image/*"
                                            name="arquivo" class="form-control" capture="environment" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="descricao" class="form-label fw-medium">Descrição:</label>
                                        <input id="descricao" name="descricao"
                                            placeholder="Relate a não conformidade encontrada..." class="form-control"
                                            required>
                                    </div>
                                    <div class="d-grid d-md-flex justify-content-md-end">
                                        <button type="submit"
                                            class="btn btn-accent rounded-pill px-4 py-2 fw-medium shadow-sm w-100 w-sm-auto">
                                            <i class="bi bi-cloud-arrow-up-fill me-2"></i>Enviar Imagem
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>